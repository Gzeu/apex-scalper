# =============================================================================
# Apex Scalper v0.5.0 — Mainnet configuration template
# Copy to .env and fill in your values.
# =============================================================================

# ───────────────────────────────────────────────────────────────────────────
# BYBIT API CREDENTIALS
# Create API key at: https://www.bybit.com/app/user/api-management
# Required permissions: Contract > Orders (Read + Write), Positions (Read + Write)
# NEVER enable: Withdrawals, Assets Transfer
# IP whitelist: add your server IP for extra security
# ───────────────────────────────────────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# Set to false for MAINNET trading
# WARNING: BYBIT_TESTNET=false will use REAL MONEY
BYBIT_TESTNET=true

# ───────────────────────────────────────────────────────────────────────────
# TRADING PARAMETERS
# These are overridden by per-symbol SYMBOL_PROFILES in config.py
# Set symbol-specific params there for best results.
# ───────────────────────────────────────────────────────────────────────────

# Primary trading symbol (single-symbol mode)
SYMBOL=BTCUSDT

# Multi-symbol mode (overrides SYMBOL)
# SYMBOLS=BTCUSDT,ETHUSDT,HYPEUSDT

# Leverage (overridden by SYMBOL_PROFILES)
LEVERAGE=5

# Order size in USDT per trade (overridden by SYMBOL_PROFILES)
# For mainnet, start conservative: $20-$50
# Never risk more than 1-2% of total capital per trade
ORDER_SIZE_USDT=20

# Maximum daily loss before bot stops for the day
# Set to ~3-5% of total capital
DAILY_LOSS_LIMIT_USDT=30

# ───────────────────────────────────────────────────────────────────────────
# ORDER EXECUTION
# ───────────────────────────────────────────────────────────────────────────

# Use Limit PostOnly orders (true = maker fee 0.020%, false = market fee 0.055%)
# STRONGLY recommended: true for mainnet
USE_LIMIT_ORDERS=true

# Entry signal threshold (0.0-1.0). Higher = fewer but cleaner signals.
# Start at 0.65 for mainnet (conservative). Lower only after backtesting confirms.
# Overridden by SYMBOL_PROFILES per symbol.
ENTRY_THRESHOLD=0.65

# ───────────────────────────────────────────────────────────────────────────
# TELEGRAM NOTIFICATIONS
# Get bot token: message @BotFather on Telegram -> /newbot
# Get chat ID: message @userinfobot or use getUpdates API
# ───────────────────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────────────────────────────────────
# ADVANCED (optional, leave defaults for mainnet start)
# ───────────────────────────────────────────────────────────────────────────

# RSI thresholds (overridden by SYMBOL_PROFILES)
RSI_LONG_MIN=52.0
RSI_SHORT_MAX=48.0
RSI_OB_LIMIT=70.0
RSI_OS_LIMIT=30.0

# Volume filter
VOL_ZSCORE_MIN=0.0

# ATR gate
ATR_MIN_PCT=0.0003
ATR_MAX_PCT=0.005

# OB imbalance thresholds
IMBALANCE_LONG=0.10
IMBALANCE_SHORT=-0.10

# Logging: DEBUG | INFO | WARNING
LOG_LEVEL=INFO

# =============================================================================
# MAINNET CHECKLIST (read before setting BYBIT_TESTNET=false)
# =============================================================================
# [ ] Run backtester: python -m apex_scalper.backtester --symbol BTCUSDT --days 90
# [ ] Run optimizer:  python -m apex_scalper.optimizer  --symbol BTCUSDT --days 90 --trials 300
#     -> OOS Sharpe must be >= 1.0 before going live
# [ ] Run on testnet for >= 7 days, verify Telegram alerts work
# [ ] API key has NO withdrawal permissions, IP-whitelisted
# [ ] DAILY_LOSS_LIMIT_USDT set to <= 5% of capital
# [ ] ORDER_SIZE_USDT set to <= 1% of capital per trade (risk management)
# [ ] BYBIT_TESTNET=true -> confirmed all orders show on testnet UI
# [ ] Docker container has restart=unless-stopped
# [ ] Server has monitoring (UptimeRobot or similar)
# =============================================================================
