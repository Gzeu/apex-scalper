# Bybit API — obligatoriu
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Testnet sau mainnet
BYBIT_TESTNET=true

# Symbol (single) sau multi-symbol
SYMBOL=BTCUSDT
# SYMBOLS=BTCUSDT,ETHUSDT

# Telegram (optional dar recomandat)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# Parametri trading (optional, default-urile din config.py sunt bune)
LEVERAGE=5
ORDER_SIZE_USDT=20
DAILY_LOSS_LIMIT_USDT=50

# Log level: DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# Pulse interval in secunde (raport Telegram periodic)
PULSE_INTERVAL_S=60
