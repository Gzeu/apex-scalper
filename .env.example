# Bybit API
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# Trading params
SYMBOL=BTCUSDT
LEVERAGE=5
ORDER_SIZE_USDT=10
DAILY_LOSS_LIMIT_USDT=30

# Strategy signals
RSI_LONG_MIN=52.0
RSI_SHORT_MAX=48.0
RSI_OB_LIMIT=70.0
RSI_OS_LIMIT=30.0
IMBALANCE_LONG=0.10
IMBALANCE_SHORT=-0.10
VOL_ZSCORE_MIN=0.0
ATR_MIN_PCT=0.0003
ATR_MAX_PCT=0.005
ENTRY_THRESHOLD=0.60

# Position management
TP1_PCT=0.0010
TP2_PCT=0.0020
SL_PCT=0.0008
TRAIL_PCT=0.0
TRAIL_DELTA=0.0005
MAX_HOLD_CANDLES=5
MAX_PYRAMID_ADDS=1

# Risk
MAX_SPREAD_BPS=5.0
MIN_BID_DEPTH=0.5
MIN_ASK_DEPTH=0.5
TRADE_HOUR_START=2
TRADE_HOUR_END=22
SKIP_SESSION_FILTER=false

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO
