# =============================================================================
# Apex Scalper v0.7.1 — Full configuration template
# Copy to .env and fill in your values.
# Parameters marked [PROFILE] are overridden per-symbol in config.py SYMBOL_PROFILES.
# =============================================================================

# ───────────────────────────────────────────────────────────────────────────
# BYBIT API CREDENTIALS
# Create at: https://www.bybit.com/app/user/api-management
# Permissions needed: Contract > Orders (Read+Write), Positions (Read+Write)
# NEVER enable: Withdrawals, Asset Transfer
# IP whitelist: add your server IP
# ───────────────────────────────────────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# WARNING: Set to false only when ready for REAL MONEY trading
BYBIT_TESTNET=true

# ───────────────────────────────────────────────────────────────────────────
# TRADING SYMBOL
# ───────────────────────────────────────────────────────────────────────────
# Single symbol mode
SYMBOL=BTCUSDT

# Multi-symbol mode (overrides SYMBOL) — v0.8.0 feature
# SYMBOLS=BTCUSDT,ETHUSDT,HYPEUSDT

# ───────────────────────────────────────────────────────────────────────────
# POSITION SIZING  [PROFILE]
# ───────────────────────────────────────────────────────────────────────────
# Leverage (1-20). Start conservative: 3-5x for testnet
LEVERAGE=5

# Base order size in USDT (before Kelly scaling)
# Mainnet: start at $20-$50. Never >1-2% of total capital.
ORDER_SIZE_USDT=20

# ───────────────────────────────────────────────────────────────────────────
# KELLY SIZING
# ───────────────────────────────────────────────────────────────────────────
# Half-Kelly multiplier (0.5 = conservative, 1.0 = full Kelly)
KELLY_FRACTION=0.5
# Number of recent trades used for Kelly calculation
KELLY_LOOKBACK=50
# Minimum trades before Kelly activates (uses fixed sizing below this)
MIN_KELLY_TRADES=20
# Kelly factor hard bounds [0.30x — 1.80x] base size
MIN_KELLY_F=0.30
MAX_KELLY_F=1.80

# ───────────────────────────────────────────────────────────────────────────
# RISK MANAGEMENT
# ───────────────────────────────────────────────────────────────────────────
# Max daily loss before bot auto-pauses. Set to ~3-5% of total capital.
MAX_DAILY_LOSS_USDT=30

# Max simultaneous open positions (1 recommended for scalping)
MAX_OPEN_POSITIONS=1

# Max consecutive losses before pause
MAX_CONSECUTIVE_LOSSES=5

# ───────────────────────────────────────────────────────────────────────────
# TAKE PROFIT / STOP LOSS  [PROFILE]
# ───────────────────────────────────────────────────────────────────────────
# 3-level scale-out. TP1+TP2+TP3 fractions must sum to 1.0
# TP1: first partial close
TP1_PCT=0.0010
TP1_FRACTION=0.25
# TP2: second partial close
TP2_PCT=0.0020
TP2_FRACTION=0.25
# TP3: final close (remainder)
TP3_PCT=0.0035
TP3_FRACTION=0.50

# Stop loss (0.0008 = 0.08%). Native exchange SL attached on entry.
SL_PCT=0.0008

# Trailing stop: activates after TRAIL_PCT profit, trails by TRAIL_DELTA
# Set TRAIL_PCT=0.0 to disable trailing stop
TRAIL_PCT=0.0
TRAIL_DELTA=0.0005

# Max candles to hold position before timeout exit
MAX_HOLD_CANDLES=5

# Max pyramid adds to a winning position
MAX_PYRAMID_ADDS=1

# ───────────────────────────────────────────────────────────────────────────
# ORDER EXECUTION
# ───────────────────────────────────────────────────────────────────────────
# Use Limit PostOnly orders (maker 0.020% vs taker 0.055%)
# STRONGLY recommended: true. Only set false if you see frequent fill failures.
USE_LIMIT_ORDERS=true

# Entry signal threshold (0.0-1.0). Higher = fewer but higher quality entries.
# 0.65 recommended for mainnet. Lower only after backtesting confirms.
ENTRY_THRESHOLD=0.65

# ───────────────────────────────────────────────────────────────────────────
# SPREAD & DEPTH FILTERS
# ───────────────────────────────────────────────────────────────────────────
# Max spread in basis points. Dynamic gate: widens in volatile markets.
MAX_SPREAD_BPS=5.0

# Min bid/ask depth (USDT) required before entry
MIN_BID_DEPTH=10000
MIN_ASK_DEPTH=10000

# ───────────────────────────────────────────────────────────────────────────
# BOOK PRESSURE  [PROFILE]
# ───────────────────────────────────────────────────────────────────────────
# Cumulative bid/ask delta threshold for pressure signal (USDT)
# Calibrate from testnet logs: check bp.cum_delta distribution
# BTCUSDT: 50000 is a starting point; adjust based on observed range
BP_BASE_THRESHOLD=50000

# ───────────────────────────────────────────────────────────────────────────
# REGIME FILTER
# ───────────────────────────────────────────────────────────────────────────
# ADX(14) minimum for TRENDING regime
ADX_TRENDING_MIN=25.0
# ADX maximum for RANGING regime
ADX_RANGING_MAX=20.0
# ATR percentile (0-100) above which = VOLATILE (50% size)
ATR_VOLATILE_PCT=80.0
# ATR percentile below which = RANGING (entries blocked)
ATR_RANGING_PCT=20.0
# Hurst exponent minimum for TRENDING (>0.55 = trending)
HURST_TREND_MIN=0.55
# Hurst exponent maximum for RANGING (<0.45 = mean-reverting)
HURST_RANGE_MAX=0.45

# ───────────────────────────────────────────────────────────────────────────
# SIGNAL THRESHOLDS  [PROFILE]
# ───────────────────────────────────────────────────────────────────────────
RSI_LONG_MIN=52.0
RSI_SHORT_MAX=48.0
RSI_OB_LIMIT=70.0
RSI_OS_LIMIT=30.0
VOL_ZSCORE_MIN=0.0
ATR_MIN_PCT=0.0003
ATR_MAX_PCT=0.005
IMBALANCE_LONG=0.10
IMBALANCE_SHORT=-0.10

# ───────────────────────────────────────────────────────────────────────────
# TELEGRAM
# ───────────────────────────────────────────────────────────────────────────
# Bot token from @BotFather | Chat ID from @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ───────────────────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# =============================================================================
# MAINNET CHECKLIST (read before setting BYBIT_TESTNET=false)
# =============================================================================
# [ ] Run optimizer:     python -m apex_scalper.optimizer --symbol BTCUSDT
# [ ] Walk-forward OOS:  python -m apex_scalper.walk_forward --symbol BTCUSDT --windows 6
#       -> Verdict must be MAINNET READY (OOS Sharpe >= 1.0)
# [ ] Testnet >= 5 days. Check /regime logs: % of time in RANGING vs TRENDING
# [ ] Calibrate BP_BASE_THRESHOLD from testnet /signals bp.cum_delta logs
# [ ] API key: NO withdrawal permissions, IP-whitelisted
# [ ] MAX_DAILY_LOSS_USDT <= 5% of total capital
# [ ] ORDER_SIZE_USDT <= 1% of total capital (base, Kelly can scale up to 1.8x)
# [ ] Confirmed all Telegram commands work on testnet
# [ ] Docker: restart=unless-stopped + external monitoring (UptimeRobot)
# =============================================================================
