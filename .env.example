# Bybit API
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# Trading params
SYMBOL=BTCUSDT
LEVERAGE=5
ORDER_SIZE_USDT=10
MAX_POSITIONS=1
DAILY_LOSS_LIMIT_USDT=30

# Strategy tuning (all optional)
TP_PCT=0.0015
SL_PCT=0.0010
TRAIL_PCT=0.0
TRAIL_DELTA=0.0005
MAX_HOLD_CANDLES=3
RSI_LONG_MIN=52.0
RSI_SHORT_MAX=48.0

# Risk / Orderbook filters
MAX_SPREAD_BPS=5.0
MIN_BID_DEPTH=0.5
MIN_ASK_DEPTH=0.5

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO
