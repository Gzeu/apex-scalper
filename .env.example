# =============================================================
# Apex Scalper — Full .env configuration
# =============================================================

# Bybit API
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_TESTNET=true

# ───────────────────────────────────────────────────────────
# OPTION A: Single symbol mode
# ───────────────────────────────────────────────────────────
# SYMBOL=BTCUSDT

# ───────────────────────────────────────────────────────────
# OPTION B: Multi-symbol mode (top 5 Bybit by 24h vol, June 2026)
# Each symbol uses its own tuned profile automatically
# ───────────────────────────────────────────────────────────
SYMBOLS=BTCUSDT,ETHUSDT,HYPEUSDT,DOGEUSDT,NEARUSDT

# Base capital per trade (per symbol)
ORDER_SIZE_USDT=10
DAILY_LOSS_LIMIT_USDT=50

# ───────────────────────────────────────────────────────────
# Manual override (ignored if using SYMBOLS= multi-mode)
# These are applied only when SYMBOL= is used (single mode)
# ───────────────────────────────────────────────────────────
LEVERAGE=5
# TP1_PCT=0.0012
# TP2_PCT=0.0025
# SL_PCT=0.0008
# TRAIL_PCT=0.0015
# TRAIL_DELTA=0.0005
# MAX_HOLD_CANDLES=5
# RSI_LONG_MIN=52
# RSI_SHORT_MAX=48
# ENTRY_THRESHOLD=0.60
# MAX_SPREAD_BPS=3.0
# MIN_BID_DEPTH=1.0
# MIN_ASK_DEPTH=1.0

# Session filter (UTC hours, skip outside range)
TRADE_HOUR_START=2
TRADE_HOUR_END=22
SKIP_SESSION_FILTER=false

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO
